# ==========================================
# Ignition Specific
# ==========================================
# Ignore Designer autosave folders and temporary lock files
.autosave/
*.lock

# Ignore Ignition backup files (if you accidentally drop them here)
*.gwbk
*.proj

# ==========================================
# Custom Repo Utilities
# ==========================================
# Ignore our custom batch sync scripts folder
util/

